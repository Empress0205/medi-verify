# ══════════════════════════════════════════════════════════════════════════════
#  ENVIRONMENT VARIABLES — copy this file to .env and adjust if needed
# ══════════════════════════════════════════════════════════════════════════════

# Base URL of the MediGuard API (services/api).
#
# Vite inlines this AT BUILD TIME, so it must be set before `npm run build` —
# setting it on the host afterwards has no effect. On Render it is supplied by
# the static-site service defined in render.yaml.

# Live backend:
VITE_API_BASE_URL=https://mediguard-api-smlx.onrender.com

# For local development against a backend running on your own machine:
# VITE_API_BASE_URL=http://localhost:8000
