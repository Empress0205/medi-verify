# ══════════════════════════════════════════════════════════════════════════════
#  ENVIRONMENT VARIABLES — copy this file to .env and fill in your values
# ══════════════════════════════════════════════════════════════════════════════

# Your Flutter/backend API base URL
VITE_API_BASE_URL=http://localhost:8080

# Set to "true" to use mock data instead of real API calls (great for dev/demo)
VITE_USE_MOCK=true
