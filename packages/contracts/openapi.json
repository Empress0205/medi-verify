            "type": "boolean",
            "title": "Reportable",
            "default": false
          }
        },
        "type": "object",
        "required": [
          "expiry_status",
          "registration_validity",
          "severity",
          "headline"
        ],
        "title": "SafetyInfo",
        "description": "The safety layer that sits on top of the registration verdict.\n\nRegistration answers \"is this product approved?\" \u2014 it says nothing about\nwhether the box in your hand is still in date. Both matter, so they are\nreported separately and `severity` decides how the result is presented."
      },
