      "ScanStatus": {
        "type": "string",
        "enum": [
          "registered",
          "not_found",
          "unknown",
          "not_medicine"
        ],
        "title": "ScanStatus",
        "description": "Outcome of a REGISTRATION check against the TMDA register.\n\nThe engine verifies that the package text matches a registered product \u2014\nit cannot prove physical authenticity, so there is deliberately no\n\"counterfeit\" value here. Counterfeit is a human conclusion, reached in\nthe dashboard by confirming a report (ReportStatus.confirmed)."
      },
