      "Severity": {
        "type": "string",
        "enum": [
          "ok",
          "caution",
          "warning",
          "danger",
          "unknown"
        ],
        "title": "Severity",
        "description": "How the result should be presented. Deliberately calibrated:\n\n`danger` is reserved for FACTS we are sure of (an expiry date we actually\nread off the pack), never for absence of evidence \u2014 a not_found is\nuncertainty, so it warns but does not scream."
      },
